{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 01 — Data Acquisition\n",
    "\n",
    "Download LiDAR tiles for any configured Southwest study area from **USGS 3DEP**.\n",
    "\n",
    "Set `active_site` in `config.yaml` to switch between:\n",
    "- `chaco` — Chaco Culture NHP, NM\n",
    "- `mesa_verde` — Mesa Verde NP, CO\n",
    "- `hohokam_phoenix` — Hohokam canal network, AZ\n",
    "- `canyon_de_chelly` — Canyon de Chelly NM, AZ"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import yaml\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "ROOT = Path('..')\n",
    "with open(ROOT / 'config.yaml') as f:\n",
    "    cfg = yaml.safe_load(f)\n",
    "\n",
    "SITE_KEY  = cfg['active_site']\n",
    "SITE      = cfg['sites'][SITE_KEY]\n",
    "RAW_DIR   = ROOT / 'data' / 'raw'\n",
    "RAW_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "bbox = SITE['bbox_wgs84']\n",
    "print(f\"Active site: {SITE['name']} ({SITE['state']})\")\n",
    "print(f\"Bounding box: {bbox}\")\n",
    "print(f\"Notes: {SITE['notes']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Query USGS National Map API for available LiDAR tiles\n",
    "TNM_API = 'https://tnmaccess.nationalmap.gov/api/v1/products'\n",
    "\n",
    "params = {\n",
    "    'datasets': 'Lidar Point Cloud (LPC)',\n",
    "    'bbox': f\"{bbox['west']},{bbox['south']},{bbox['east']},{bbox['north']}\",\n",
    "    'prodFormats': 'LAZ',\n",
    "    'outputFormat': 'JSON',\n",
    "    'max': 50\n",
    "}\n",
    "\n",
    "resp = requests.get(TNM_API, params=params, timeout=30)\n",
    "items = resp.json().get('items', [])\n",
    "\n",
    "print(f\"Found {len(items)} LiDAR tiles\")\n",
    "total_gb = sum(i.get('sizeInBytes', 0) for i in items) / 1e9\n",
    "print(f\"Total size: {total_gb:.2f} GB\")\n",
    "print()\n",
    "for item in items:\n",
    "    print(f\"  {item['title']}\")\n",
    "    print(f\"    {item.get('sizeInBytes',0)/1e6:.0f} MB  —  {item['downloadURL']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def download_tile(url, dest_dir, chunk_size=8192):\n",
    "    fname = url.split('/')[-1]\n",
    "    dest  = dest_dir / fname\n",
    "    if dest.exists():\n",
    "        print(f'  Skipping {fname} (exists)')\n",
    "        return dest\n",
    "    resp  = requests.get(url, stream=True, timeout=60)\n",
    "    total = int(resp.headers.get('content-length', 0))\n",
    "    with open(dest, 'wb') as f, tqdm(desc=fname, total=total, unit='B', unit_scale=True) as bar:\n",
    "        for chunk in resp.iter_content(chunk_size):\n",
    "            f.write(chunk)\n",
    "            bar.update(len(chunk))\n",
    "    return dest\n",
    "\n",
    "print(f\"Downloading {len(items)} tiles to {RAW_DIR}...\")\n",
    "for item in items:\n",
    "    download_tile(item['downloadURL'], RAW_DIR)\n",
    "print('Done.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Inventory\n",
    "laz_files = sorted(RAW_DIR.glob('*.laz')) + sorted(RAW_DIR.glob('*.las'))\n",
    "print(f\"{len(laz_files)} point cloud files in data/raw/:\")\n",
    "for f in laz_files:\n",
    "    print(f\"  {f.name}  ({f.stat().st_size/1e6:.0f} MB)\")"
   ]
  }
 ],
