   "source": [
    "# 02 — 3D Terrain Rendering (forge3d)\n",
    "\n",
    "Render the DEM using `forge3d`'s headless path tracer — no Rust toolchain, no viewer binary required.\n",
    "\n",
    "## How forge3d's path tracer works\n",
    "\n",
    "```\n",
    "DEM array (float32)\n",
    "    ↓\n",
    "create_path_tracer(width, height)    ← sets up BVH + ray pipeline on CPU/GPU\n",
    "    ↓\n",
    "make_camera(origin, look_at, ...)    ← defines viewpoint\n",
    "    ↓\n",
    "render_rgba(tracer, dem, camera, samples=N)  ← fires N rays per pixel\n",
    "    ↓\n",
    "RGBA uint8 array  →  save_png(path, array)\n",
    "```\n",
    "\n",
    "More samples = less noise, longer render time. 32 = fast preview, 128+ = publication quality."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import math\n",
    "import numpy as np\n",
    "import yaml\n",
    "import rasterio\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.image as mpimg\n",
    "from pathlib import Path\n",
    "from forge3d import path_tracing\n",
    "from forge3d._png import save_png\n",
    "\n",
    "ROOT = Path('..')\n",
    "with open(ROOT / 'config.yaml') as f:\n",
    "    cfg = yaml.safe_load(f)\n",
    "\n",
    "SITE_KEY    = cfg['active_site']\n",
    "SITE        = cfg['sites'][SITE_KEY]\n",
    "RENDER_CFG  = cfg['render']\n",
    "DEM_PATH    = ROOT / cfg['dem']['output_dir'] / f'{SITE_KEY}_dem_1m.tif'\n",
    "RENDERS_DIR = ROOT / RENDER_CFG['output_dir']\n",
    "RENDERS_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print(f\"Site:     {SITE['name']}\")\n",
    "print(f\"DEM:      {DEM_PATH}\")\n",
    "print(f\"Exists:   {DEM_PATH.exists()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_dem(path):\n",
    "    \"\"\"Load GeoTIFF as float32 array, fill nodata with mean.\"\"\"\n",
    "    with rasterio.open(path) as src:\n",
    "        dem = src.read(1).astype(np.float32)\n",
    "        nd  = src.nodata\n",
    "    if nd is not None:\n",
    "        dem[dem == nd] = np.nan\n",
    "    dem[np.isnan(dem)] = float(np.nanmean(dem))\n",
    "    return dem\n",
    "\n",
    "def make_orbit_camera(dem, phi_deg, theta_deg, radius, width, height, fov_y=45.0):\n",
    "    \"\"\"Build a forge3d camera dict from spherical orbit parameters.\"\"\"\n",
    "    phi   = math.radians(phi_deg)\n",
    "    theta = math.radians(theta_deg)\n",
    "    rows, cols = dem.shape\n",
    "    cx, cy = 0.5, 0.5\n",
    "    cz = float(np.nanmean((dem - dem.min()) / (dem.max() - dem.min() + 1e-8)))\n",
    "    look_at = (cx, cy, cz)\n",
    "    origin  = (\n",
    "        cx + radius * math.sin(theta) * math.cos(phi),\n",
    "        cy + radius * math.sin(theta) * math.sin(phi),\n",
    "        cz + radius * math.cos(theta),\n",
    "    )\n",
    "    return path_tracing.make_camera(\n",
    "        origin=origin, look_at=look_at, up=(0, 0, 1),\n",
    "        fov_y=fov_y, aspect=width/height, exposure=1.0\n",
    "    )\n",
    "\n",
    "def render(dem, out_path, phi=225, theta=35, radius=1.3,\n",
    "           width=1920, height=1080, samples=64, max_bounces=2):\n",
    "    \"\"\"Render a DEM array and save to PNG.\"\"\"\n",
    "    camera = make_orbit_camera(dem, phi, theta, radius, width, height)\n",
    "    tracer = path_tracing.create_path_tracer(width, height, max_bounces=max_bounces, seed=42)\n",
    "    rgba   = path_tracing.render_rgba(tracer, dem, camera, samples=samples)\n",
    "    save_png(str(out_path), rgba)\n",
    "    return rgba\n",
    "\n",
    "print(\"Helper functions ready.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Quick preview render (32 samples)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dem = load_dem(DEM_PATH)\n",
    "print(f\"DEM shape: {dem.shape}  Elevation: {dem.min():.1f}–{dem.max():.1f}m\")\n",
    "\n",
    "preview_path = RENDERS_DIR / f'{SITE_KEY}_preview.png'\n",
    "print(\"Rendering preview...\")\n",
    "rgba = render(dem, preview_path, width=1280, height=720, samples=32)\n",
    "print(f\"Done — {preview_path.name}\")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 8), facecolor='#0d0d0d')\n",
    "ax.imshow(rgba)\n",
    "ax.axis('off')\n",
    "ax.set_title(f\"{SITE['name']} — forge3d preview\",\n",
    "             color='#e8d5a3', fontsize=13, fontfamily='serif')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4K hero render (64 samples)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "hero_path = RENDERS_DIR / f'{SITE_KEY}_hero_4k.png'\n",
    "print(\"Rendering 4K hero image (this takes a minute)...\")\n",
    "render(dem, hero_path,\n",
    "       phi=RENDER_CFG['default_camera']['phi_deg'],\n",
    "       theta=RENDER_CFG['default_camera']['theta_deg'],\n",
    "       radius=RENDER_CFG['default_camera']['radius'],\n",
    "       width=RENDER_CFG['snapshot_width'],\n",
    "       height=RENDER_CFG['snapshot_height'],\n",
    "       samples=64)\n",
    "print(f\"Saved: {hero_path}  ({hero_path.stat().st_size/1e6:.1f} MB)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4-angle panel"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from PIL import Image\n",
    "\n",
    "ANGLES = [\n",
    "    (225, 35, 'SE oblique'),\n",
    "    (315, 45, 'NW oblique'),\n",
    "    (180, 20, 'S low'),\n",
    "    (0,   90, 'Nadir'),\n",
    "]\n",
    "\n",
    "W, H = 1280, 720\n",
    "panel_imgs = []\n",
    "\n",
    "for phi, theta, label in ANGLES:\n",
    "    p = RENDERS_DIR / f\"{SITE_KEY}_{label.lower().replace(' ','_')}.png\"\n",
    "    print(f\"  {label}...\")\n",
    "    rgba = render(dem, p, phi=phi, theta=theta, width=W, height=H, samples=32)\n",
    "    panel_imgs.append((label, rgba))\n",
    "\n",
    "# Display panel\n",
    "fig, axes = plt.subplots(2, 2, figsize=(18, 10), facecolor='#0d0d0d')\n",
    "for ax, (label, img) in zip(axes.ravel(), panel_imgs):\n",
    "    ax.imshow(img)\n",
    "    ax.set_title(label, color='#e8d5a3', fontsize=11, fontfamily='serif')\n",
    "    ax.axis('off')\n",
    "    ax.set_facecolor('#0d0d0d')\n",
    "plt.suptitle(f\"{SITE['name']} — Multi-Angle Renders\",\n",
    "             color='#e8d5a3', fontsize=14, fontfamily='serif')\n",
    "plt.tight_layout()\n",
    "panel_out = RENDERS_DIR / f'{SITE_KEY}_panel.png'\n",
    "plt.savefig(panel_out, dpi=150, bbox_inches='tight', facecolor='#0d0d0d')\n",
    "plt.show()\n",
    "print(f\"Panel saved: {panel_out}\")"
   ]
  },
